#!/usr/bin/env bash
# cfo-stack setup — install dependencies + register skills with Claude Code / Codex / OpenClaw / Antigravity
# Modeled after gstack's setup script
set -euo pipefail

CFO_STACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$CFO_STACK_DIR")"
VENV_DIR="$CFO_STACK_DIR/.venv"
VENV_BIN="$VENV_DIR/bin"
VENV_PY="$VENV_BIN/python"

# ─── Parse --host flag ─────────────────────────────────────────
HOST="claude"
while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      if [ $# -lt 2 ]; then
        echo "Error: --host requires a value (claude, codex, openclaw, antigravity, or auto)" >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|openclaw|antigravity|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, openclaw, antigravity, or auto)" >&2; exit 1 ;;
esac

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_OPENCLAW=0
INSTALL_ANTIGRAVITY=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v openclaw >/dev/null 2>&1 && INSTALL_OPENCLAW=1
  command -v antigravity >/dev/null 2>&1 && INSTALL_ANTIGRAVITY=1
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_OPENCLAW" -eq 0 ] && [ "$INSTALL_ANTIGRAVITY" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "openclaw" ]; then
  INSTALL_OPENCLAW=1
elif [ "$HOST" = "antigravity" ]; then
  INSTALL_ANTIGRAVITY=1
fi

echo "╔══════════════════════════════════════════╗"
echo "║          CFO Stack Setup                 ║"
echo "║    AI-Powered Accounting with CLEAR      ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# ─── 1. Check Python ─────────────────────────────────────────
PYTHON=""
if command -v python3 >/dev/null 2>&1; then
  PYTHON="python3"
elif command -v python >/dev/null 2>&1; then
  PYTHON="python"
fi

if [ -z "$PYTHON" ]; then
  echo "Error: Python 3 is required but not installed." >&2
  echo "  macOS:   brew install python" >&2
  echo "  Ubuntu:  sudo apt install python3" >&2
  echo "  Windows: https://python.org/downloads/" >&2
  exit 1
fi

PY_VERSION=$($PYTHON -c "import sys; print(str(sys.version_info.major) + '.' + str(sys.version_info.minor))")
PY_MAJOR=$($PYTHON -c "import sys; print(sys.version_info.major)")
PY_MINOR=$($PYTHON -c "import sys; print(sys.version_info.minor)")

if [ "$PY_MAJOR" -lt 3 ] || { [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 10 ]; }; then
  echo "Error: Python 3.10+ required by the current dependency set, found $PY_VERSION" >&2
  exit 1
fi

echo "  Python: $($PYTHON --version)"

# ─── 2. Check Git ─────────────────────────────────────────────
if ! command -v git >/dev/null 2>&1; then
  echo "Error: git is required but not installed." >&2
  exit 1
fi
echo "  Git: $(git --version | head -1)"

# ─── 3. Check uv ─────────────────────────────────────────────
UV=""
if command -v uv >/dev/null 2>&1; then
  UV="uv"
  echo "  uv: $(uv --version | head -1)"
else
  echo "Error: uv is required but not installed." >&2
  echo "  Install it: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
  exit 1
fi

# ─── 4. Create local virtual environment ─────────────────────
echo ""
echo "Creating local virtual environment..."
uv venv --allow-existing --python "$PYTHON" "$VENV_DIR"
echo "  Virtualenv: $VENV_DIR"

# ─── 5. Install Python dependencies ──────────────────────────
echo ""
echo "Installing Python dependencies via uv..."

if ! uv pip install --python "$VENV_PY" --quiet \
  beancount \
  fava \
  beangulp \
  beanquery; then
  echo "Error: Failed to install Python dependencies." >&2
  echo "  Try running: uv pip install --python \"$VENV_PY\" beancount fava beangulp beanquery" >&2
  exit 1
fi

# Verify Beancount works
if "$VENV_PY" -c "import beancount" 2>/dev/null; then
  BC_VERSION=$("$VENV_PY" -c "import beancount; print(beancount.__version__)" 2>/dev/null || echo "installed")
  echo "  Beancount: $BC_VERSION"
else
  echo "Error: Beancount installed but could not be imported." >&2
  exit 1
fi

# Verify Fava
if "$VENV_PY" -c "import fava" 2>/dev/null; then
  echo "  Fava: installed"
else
  echo "Error: Fava could not be imported." >&2
  exit 1
fi

if [ ! -x "$VENV_BIN/bean-check" ]; then
  echo "Error: bean-check was not installed into $VENV_BIN." >&2
  exit 1
fi

if [ ! -x "$VENV_BIN/fava" ]; then
  echo "Error: fava executable was not installed into $VENV_BIN." >&2
  exit 1
fi

# ─── 6. Create state directory + default policy config ─────────
STATE_DIR="$HOME/.cfo-stack"
GLOBAL_CONFIG="$STATE_DIR/config.yaml"
mkdir -p "$STATE_DIR"
echo "  State dir: ~/.cfo-stack/"

if [ ! -f "$GLOBAL_CONFIG" ]; then
  cat > "$GLOBAL_CONFIG" <<'YAML'
# yaml-language-server: $schema=https://raw.githubusercontent.com/MikeChongCan/cfo-stack/main/schemas/policy.schema.json
version: 1
review_policy:
  large_transaction_human_confirmation:
    enabled: true
    amount: 1000
    currency_mode: ledger_operating_currency
    note: >-
      Default review threshold installed by CFO Stack setup. Ledger-local
      cfo-stack.yaml may override this value.
YAML
  echo "  Default policy: $GLOBAL_CONFIG"
else
  echo "  Default policy: $GLOBAL_CONFIG (existing)"
fi

# ─── 7. Helper: symlink skill subdirectories ──────────────────
link_skill_dirs() {
  local cfo_dir="$1"
  local skills_dir="$2"
  local prefix="$3"
  local linked=()
  for skill_dir in "$cfo_dir"/skills/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="${prefix}$(basename "$skill_dir")"
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  Linked skills: ${linked[*]}"
  fi
}

# ─── 8. Install for Claude Code ───────────────────────────────
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  echo ""
  echo "Registering with Claude Code..."
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    link_skill_dirs "$CFO_STACK_DIR" "$SKILLS_DIR" "cfo-"
    echo "  cfo-stack ready (claude)."
  else
    echo "  cfo-stack ready (claude)."
    echo "  (skipped skill symlinks — not inside .claude/skills/)"
  fi
fi

# ─── 9. Install for Codex ────────────────────────────────────
if [ "$INSTALL_CODEX" -eq 1 ]; then
  echo ""
  echo "Registering with Codex..."
  CODEX_SKILLS="$HOME/.codex/skills"
  mkdir -p "$CODEX_SKILLS"
  link_skill_dirs "$CFO_STACK_DIR" "$CODEX_SKILLS" "cfo-"
  echo "  cfo-stack ready (codex)."
  echo "  codex skills: $CODEX_SKILLS"
fi

# ─── 10. Install for OpenClaw ─────────────────────────────────
if [ "$INSTALL_OPENCLAW" -eq 1 ]; then
  echo ""
  echo "Registering with OpenClaw..."
  OPENCLAW_SKILLS="$HOME/.openclaw/skills"
  mkdir -p "$OPENCLAW_SKILLS"
  link_skill_dirs "$CFO_STACK_DIR" "$OPENCLAW_SKILLS" "cfo-"
  echo "  cfo-stack ready (openclaw)."
  echo "  openclaw skills: $OPENCLAW_SKILLS"
fi

# ─── 11. Install for Antigravity ──────────────────────────────
if [ "$INSTALL_ANTIGRAVITY" -eq 1 ]; then
  echo ""
  echo "Registering with Antigravity..."
  ANTIGRAVITY_SKILLS="$HOME/.gemini/antigravity/skills"
  mkdir -p "$ANTIGRAVITY_SKILLS"
  link_skill_dirs "$CFO_STACK_DIR" "$ANTIGRAVITY_SKILLS" "cfo-"
  echo "  cfo-stack ready (antigravity)."
  echo "  antigravity skills: $ANTIGRAVITY_SKILLS"
fi

# ─── 12. Create helper scripts ────────────────────────────────
mkdir -p "$CFO_STACK_DIR/bin"

# cfo-check: bean-check wrapper
cat > "$CFO_STACK_DIR/bin/cfo-check" << 'SCRIPT'
#!/usr/bin/env bash
# Wrapper around bean-check with colored output
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VENV_BIN="$ROOT_DIR/.venv/bin"
LEDGER="${1:-}"
if [ -z "$LEDGER" ]; then
  if [ -f "./main.beancount" ]; then
    LEDGER="./main.beancount"
  elif [ -f "./ledger/main.beancount" ]; then
    LEDGER="./ledger/main.beancount"
  else
    LEDGER="$(find . -type f -name main.beancount | head -n 1 || true)"
  fi
fi
if [ -z "$LEDGER" ]; then
  echo "Error: no ledger found. Pass a Beancount file explicitly or create main.beancount." >&2
  exit 1
fi
if [ ! -f "$LEDGER" ]; then
  echo "Error: $LEDGER not found" >&2
  exit 1
fi
"$VENV_BIN/bean-check" "$LEDGER" 2>&1
echo "Ledger OK: $LEDGER"
SCRIPT
chmod +x "$CFO_STACK_DIR/bin/cfo-check"

# cfo-fava: Fava launcher
cat > "$CFO_STACK_DIR/bin/cfo-fava" << 'SCRIPT'
#!/usr/bin/env bash
# Launch Fava web UI
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VENV_BIN="$ROOT_DIR/.venv/bin"
LEDGER="${1:-}"
PORT="${2:-5000}"
if [ -z "$LEDGER" ]; then
  if [ -f "./main.beancount" ]; then
    LEDGER="./main.beancount"
  elif [ -f "./ledger/main.beancount" ]; then
    LEDGER="./ledger/main.beancount"
  else
    LEDGER="$(find . -type f -name main.beancount | head -n 1 || true)"
  fi
fi
if [ -z "$LEDGER" ]; then
  echo "Error: no ledger found. Pass a Beancount file explicitly or create main.beancount." >&2
  exit 1
fi
if [ ! -f "$LEDGER" ]; then
  echo "Error: $LEDGER not found" >&2
  exit 1
fi
echo "Starting Fava (read-only) on http://localhost:$PORT ..."
"$VENV_BIN/fava" "$LEDGER" --port "$PORT" --read-only
SCRIPT
chmod +x "$CFO_STACK_DIR/bin/cfo-fava"

# cfo-dashboard: deterministic HTML dashboard generator
cat > "$CFO_STACK_DIR/bin/cfo-dashboard" << 'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCRIPTS_DIR="$ROOT_DIR/skills/report-dashboard/scripts"

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required for cfo-dashboard." >&2
  echo "Install Bun from https://bun.sh and run this command again." >&2
  exit 1
fi

if [ ! -d "$SCRIPTS_DIR/node_modules" ]; then
  echo "Installing dashboard dependencies with Bun..."
  (cd "$SCRIPTS_DIR" && bun install)
fi

exec bun --cwd "$SCRIPTS_DIR" run generate -- "$@"
SCRIPT
chmod +x "$CFO_STACK_DIR/bin/cfo-dashboard"

# ─── 13. Done ─────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════╗"
echo "║          Setup Complete!                 ║"
echo "╠══════════════════════════════════════════╣"
echo "║                                          ║"
echo "║  Quick start:                            ║"
echo "║    1. Run /setup to create your ledger   ║"
echo "║    2. Edit ~/.cfo-stack/config.yaml      ║"
echo "║       if you want a different review     ║"
echo "║       threshold than \$1,000             ║"
echo "║    3. Drop bank CSVs in ~/Downloads      ║"
echo "║    4. Run /capture to import them        ║"
echo "║    5. Run /classify to categorize        ║"
echo "║    6. Run /report to see your finances   ║"
echo "║    7. Run ./bin/cfo-dashboard            ║"
echo "║                                          ║"
echo "║  The CLEAR cycle:                        ║"
echo "║    Capture → Log → Extract →              ║"
echo "║    Automate → Report                      ║"
echo "║                                          ║"
echo "╚══════════════════════════════════════════╝"
