#!/usr/bin/env bash
# cfo-stack uninstall — unregister skills and optionally remove local tooling/state
set -euo pipefail

CFO_STACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$CFO_STACK_DIR")"
STATE_DIR="$HOME/.cfo-stack"
GLOBAL_CONFIG="$STATE_DIR/config.yaml"
REMOVE_LOCAL_TOOLS=0
REMOVE_STATE=0
HOST="auto"
SCOPE="machine"
PROJECT_DIR=""
RUN_DIR="$(pwd -P)"

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      if [ $# -lt 2 ]; then
        echo "Error: --host requires a value (claude, codex, openclaw, antigravity, or auto)" >&2
        exit 1
      fi
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#--host=}"
      shift
      ;;
    --scope)
      if [ $# -lt 2 ]; then
        echo "Error: --scope requires a value (machine or project)" >&2
        exit 1
      fi
      SCOPE="$2"
      shift 2
      ;;
    --scope=*)
      SCOPE="${1#--scope=}"
      shift
      ;;
    --project-dir)
      if [ $# -lt 2 ]; then
        echo "Error: --project-dir requires a directory path" >&2
        exit 1
      fi
      PROJECT_DIR="$2"
      shift 2
      ;;
    --project-dir=*)
      PROJECT_DIR="${1#--project-dir=}"
      shift
      ;;
    --remove-local-tools)
      REMOVE_LOCAL_TOOLS=1
      shift
      ;;
    --remove-state)
      REMOVE_STATE=1
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

case "$HOST" in
  claude|codex|openclaw|antigravity|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, openclaw, antigravity, or auto)" >&2; exit 1 ;;
esac

case "$SCOPE" in
  machine|project) ;;
  *) echo "Unknown --scope value: $SCOPE (expected machine or project)" >&2; exit 1 ;;
esac

if [ "$SCOPE" = "machine" ] && [ -n "$PROJECT_DIR" ]; then
  echo "Error: --project-dir is only valid with --scope project" >&2
  exit 1
fi

if [ "$SCOPE" = "project" ]; then
  if [ -z "$PROJECT_DIR" ]; then
    if [ "$RUN_DIR" = "$CFO_STACK_DIR" ]; then
      echo "Error: --scope project requires --project-dir when run from the CFO Stack repo." >&2
      exit 1
    fi
    PROJECT_DIR="$RUN_DIR"
  fi
  if [ ! -d "$PROJECT_DIR" ]; then
    echo "Error: project directory not found: $PROJECT_DIR" >&2
    exit 1
  fi
  PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd -P)"
fi

REMOVE_CLAUDE=0
REMOVE_CODEX=0
REMOVE_OPENCLAW=0
REMOVE_ANTIGRAVITY=0

if [ "$HOST" = "auto" ]; then
  REMOVE_CLAUDE=1
  REMOVE_CODEX=1
  REMOVE_OPENCLAW=1
  REMOVE_ANTIGRAVITY=1
elif [ "$HOST" = "claude" ]; then
  REMOVE_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  REMOVE_CODEX=1
elif [ "$HOST" = "openclaw" ]; then
  REMOVE_OPENCLAW=1
elif [ "$HOST" = "antigravity" ]; then
  REMOVE_ANTIGRAVITY=1
fi

echo "╔══════════════════════════════════════════╗"
echo "║        CFO Stack Uninstall               ║"
echo "║     Remove host registrations safely     ║"
echo "╚══════════════════════════════════════════╝"
echo ""
echo "  Scope: $SCOPE"
if [ "$SCOPE" = "project" ]; then
  echo "  Project dir: $PROJECT_DIR"
fi

remove_skill_links() {
  local skills_root="$1"
  local prefix="$2"
  local removed=()
  local skill_dir
  local clean_skill_dir
  local skill_name
  local target
  local current_target

  [ -d "$skills_root" ] || return 0

  for skill_dir in "$CFO_STACK_DIR"/skills/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      clean_skill_dir="${skill_dir%/}"
      skill_name="${prefix}$(basename "$skill_dir")"
      target="$skills_root/$skill_name"
      if [ -L "$target" ]; then
        current_target="$(readlink "$target" || true)"
        if [ "$current_target" = "$skill_dir" ] || [ "$current_target" = "$clean_skill_dir" ]; then
          rm "$target"
          removed+=("$skill_name")
        fi
      fi
    fi
  done

  if [ ${#removed[@]} -gt 0 ]; then
    echo "  Removed skills: ${removed[*]}"
  else
    echo "  No CFO Stack skill links found in $skills_root"
  fi
}

SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$REMOVE_CLAUDE" -eq 1 ]; then
  echo "Unregistering from Claude Code..."
  if [ "$SCOPE" = "project" ]; then
    remove_skill_links "$PROJECT_DIR/.claude/skills" "cfo-"
  elif [ "$SKILLS_BASENAME" = "skills" ]; then
    remove_skill_links "$SKILLS_DIR" "cfo-"
  else
    echo "  Skipped Claude symlink cleanup — repo is not inside a skills directory"
  fi
  echo ""
fi

if [ "$REMOVE_CODEX" -eq 1 ]; then
  echo "Unregistering from Codex..."
  if [ "$SCOPE" = "project" ]; then
    remove_skill_links "$PROJECT_DIR/.agents/skills" "cfo-"
  else
    remove_skill_links "$HOME/.codex/skills" "cfo-"
  fi
  echo ""
fi

if [ "$REMOVE_OPENCLAW" -eq 1 ]; then
  echo "Unregistering from OpenClaw..."
  if [ "$SCOPE" = "project" ]; then
    remove_skill_links "$PROJECT_DIR/.agents/skills" "cfo-"
  else
    remove_skill_links "$HOME/.openclaw/skills" "cfo-"
  fi
  echo ""
fi

if [ "$REMOVE_ANTIGRAVITY" -eq 1 ]; then
  echo "Unregistering from Antigravity..."
  if [ "$SCOPE" = "project" ]; then
    remove_skill_links "$PROJECT_DIR/.agents/skills" "cfo-"
  else
    remove_skill_links "$HOME/.gemini/antigravity/skills" "cfo-"
  fi
  echo ""
fi

if [ "$REMOVE_LOCAL_TOOLS" -eq 1 ]; then
  echo "Removing repo-local tooling..."
  rm -f "$CFO_STACK_DIR/bin/cfo-check" "$CFO_STACK_DIR/bin/cfo-fava" "$CFO_STACK_DIR/bin/cfo-dashboard"
  if [ -d "$CFO_STACK_DIR/bin" ] && [ -z "$(find "$CFO_STACK_DIR/bin" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    rmdir "$CFO_STACK_DIR/bin"
    echo "  Removed empty bin/"
  fi
  rm -rf "$CFO_STACK_DIR/skills/report-dashboard/scripts/node_modules"
  rm -rf "$CFO_STACK_DIR/.venv"
  echo "  Removed .venv, generated helper scripts, and dashboard node_modules"
  echo ""
fi

if [ "$REMOVE_STATE" -eq 1 ]; then
  if [ "$SCOPE" = "project" ]; then
    echo "Skipping global CFO Stack state removal in project scope."
  else
    echo "Removing global CFO Stack state..."
    rm -f "$GLOBAL_CONFIG"
    if [ -d "$STATE_DIR" ] && [ -z "$(find "$STATE_DIR" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
      rmdir "$STATE_DIR"
      echo "  Removed empty $STATE_DIR"
    else
      echo "  Removed $GLOBAL_CONFIG"
    fi
    echo ""
  fi
fi

echo "Done."
